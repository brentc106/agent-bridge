# Agent Bridge — Environment Variables
# Copy this file to .env and fill in your keys

# ── LLM Providers ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
GEMINI_API_KEY=
OLLAMA_HOST=http://localhost:11434

# ── Telegram Transport ────────────────────────────────────────────────────
# Create two bots via @BotFather and paste the tokens here
BOT_A_TOKEN=
BOT_B_TOKEN=

# Add both bots to a group — auto-detected on first message, or paste here
TELEGRAM_GROUP_ID=

# Which providers to use for each bot
TELEGRAM_PROVIDER_A=minimax
TELEGRAM_PROVIDER_B=anthropic

# Optional model overrides (leave blank for provider defaults)
MODEL_A=
MODEL_B=

# Agent role preset (builder-reviewer, debater, planner-critic, teacher-student, cto-engineer)
TELEGRAM_PRESET=builder-reviewer

# Max turns per session
TELEGRAM_MAX_TURNS=8

# ── Web UI ────────────────────────────────────────────────────────────────
WEBUI_PORT=3737
